    {"id": "V5.3.6",  "chapter": "Validation - Output Encoding", "text": "Application protects against LDAP injection", "level": 1, "related_cwes": ["CWE-90"], "detectors": []},
    {"id": "V5.3.7",  "chapter": "Validation - Output Encoding", "text": "Application protects against XPath injection", "level": 1, "related_cwes": ["CWE-643"], "detectors": []},
