    {"id": "V5.5.3",  "chapter": "Validation - Deserialization", "text": "Deserialization of untrusted data is avoided or protected", "level": 1, "related_cwes": ["CWE-502"], "detectors": ["native:unsafe-deserialization"]},
    {"id": "V7.1.1",  "chapter": "Error Handling and Logging", "text": "Application does not log credentials or payment details", "level": 1, "related_cwes": ["CWE-532"], "detectors": ["native:log-secret-exposure"]},
    {"id": "V7.1.3",  "chapter": "Error Handling and Logging", "text": "Application logs security-relevant events", "level": 2, "related_cwes": ["CWE-778"], "detectors": []},
    {"id": "V7.4.1",  "chapter": "Error Handling and Logging", "text": "Generic error messages exposed to the user", "level": 1, "related_cwes": ["CWE-209"], "detectors": []},
