    {"id": "V5.2.6",  "chapter": "Validation - Sanitization", "text": "Application protects against SSRF", "level": 1, "related_cwes": ["CWE-918"], "detectors": ["native:ssrf-user-url", "semgrep:p/ssrf"]},
