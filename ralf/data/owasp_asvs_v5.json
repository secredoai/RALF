  "description": "Curated subset of OWASP ASVS v5 requirements that are pattern-detectable by RALF's code scanner. ASVS groups requirements into 14 chapters; this bundle focuses on the requirements our detectors can verify automatically. Requirements that need manual review are omitted.",
  "requirements": [
    {"id": "V1.2.3",  "chapter": "Architecture", "text": "Use of an allowlist approach on the trust boundary, where possible", "level": 2, "related_cwes": ["CWE-20"], "detectors": ["semgrep:p/input-validation"]},
    {"id": "V1.4.4",  "chapter": "Access Control Architecture", "text": "Enforce access control rules on a trusted service layer", "level": 2, "related_cwes": ["CWE-284", "CWE-862"], "detectors": ["semgrep:p/auth"]},
    {"id": "V2.1.1",  "chapter": "Authentication - Password Strength", "text": "User-set passwords are at least 12 characters in length", "level": 1, "related_cwes": ["CWE-521"], "detectors": []},
    {"id": "V2.1.7",  "chapter": "Authentication - Password Strength", "text": "Passwords checked against a breached-password set at registration or change", "level": 2, "related_cwes": ["CWE-521"], "detectors": []},
    {"id": "V2.4.1",  "chapter": "Credential Storage", "text": "Passwords are stored using an adaptive hash function (Argon2id / scrypt / bcrypt / PBKDF2)", "level": 1, "related_cwes": ["CWE-916"], "detectors": ["native:weak-password-hash"]},
    {"id": "V2.4.3",  "chapter": "Credential Storage", "text": "PBKDF2 iterations at or above OWASP-recommended minimums", "level": 2, "related_cwes": ["CWE-916"], "detectors": []},
    {"id": "V2.6.1",  "chapter": "Session - Token Generation", "text": "One-time tokens generated using a CSPRNG and at least 128 bits of entropy", "level": 1, "related_cwes": ["CWE-330"], "detectors": []},
    {"id": "V2.9.1",  "chapter": "Authentication - Cryptographic Software", "text": "Secrets are protected from disclosure via secret management - no hardcoded secrets in source", "level": 1, "related_cwes": ["CWE-798"], "detectors": ["native:hardcoded-credentials", "semgrep:p/secrets", "semgrep:p/gitleaks"]},
    {"id": "V3.1.1",  "chapter": "Session - Fundamental", "text": "Session tokens only transmitted over TLS", "level": 1, "related_cwes": ["CWE-319"], "detectors": []},
    {"id": "V3.3.1",  "chapter": "Session - Cookie-based", "text": "Logout invalidates the session token on the server", "level": 1, "related_cwes": ["CWE-613"], "detectors": []},
    {"id": "V3.4.1",  "chapter": "Session - Cookie-based", "text": "Cookies marked with Secure attribute", "level": 1, "related_cwes": ["CWE-614"], "detectors": []},
    {"id": "V3.4.2",  "chapter": "Session - Cookie-based", "text": "Cookies marked with HttpOnly attribute", "level": 1, "related_cwes": ["CWE-1004"], "detectors": []},
    {"id": "V3.4.3",  "chapter": "Session - Cookie-based", "text": "Cookies use SameSite attribute (Strict or Lax)", "level": 1, "related_cwes": ["CWE-1275"], "detectors": ["semgrep:p/cookie-security"]},
    {"id": "V4.1.1",  "chapter": "Access Control - General", "text": "Trusted enforcement points at gateway, services, APIs", "level": 1, "related_cwes": ["CWE-602"], "detectors": []},
    {"id": "V4.2.2",  "chapter": "Access Control - Operation-level", "text": "CSRF defenses in place (anti-CSRF token, SameSite cookie, Origin verification)", "level": 1, "related_cwes": ["CWE-352"], "detectors": ["native:framework-csrf-missing", "semgrep:p/csrf"]},
    {"id": "V4.3.2",  "chapter": "Access Control - Other", "text": "Directory browsing disabled unless deliberately desired", "level": 1, "related_cwes": ["CWE-548"], "detectors": []},
    {"id": "V5.1.1",  "chapter": "Validation - Input Validation", "text": "Application has defenses against HTTP parameter pollution", "level": 1, "related_cwes": ["CWE-235"], "detectors": []},
    {"id": "V5.1.3",  "chapter": "Validation - Input Validation", "text": "All input fields are validated using positive validation (allowlists)", "level": 1, "related_cwes": ["CWE-20"], "detectors": ["semgrep:p/input-validation"]},
    {"id": "V5.1.4",  "chapter": "Validation - Input Validation", "text": "Structured data is strongly typed and validated", "level": 1, "related_cwes": ["CWE-20"], "detectors": []},
    {"id": "V5.2.1",  "chapter": "Validation - Sanitization", "text": "All untrusted HTML from WYSIWYG editors properly sanitized", "level": 1, "related_cwes": ["CWE-79"], "detectors": ["semgrep:p/xss"]},
    {"id": "V5.2.3",  "chapter": "Validation - Sanitization", "text": "Application sanitizes user input before passing to mail systems (SMTP/IMAP injection)", "level": 1, "related_cwes": ["CWE-147"], "detectors": []},
