    {"id": "V5.5.1",  "chapter": "Validation - Deserialization", "text": "Serialized objects use integrity checks to prevent creation of hostile objects", "level": 1, "related_cwes": ["CWE-502"], "detectors": ["native:unsafe-deserialization", "semgrep:p/cwe-502"]},
