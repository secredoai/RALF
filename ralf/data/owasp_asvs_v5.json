    {"id": "V5.3.1",  "chapter": "Validation - Output Encoding", "text": "Output encoding relevant to the interpreter (HTML, JS, CSS, SQL)", "level": 1, "related_cwes": ["CWE-116"], "detectors": ["semgrep:p/xss"]},
